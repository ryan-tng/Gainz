# Kit (ConvertKit) credentials for the waitlist form.
# 1. Create a Kit account and a form named "Gainz Waitlist".
# 2. API key: Kit dashboard → Settings → Advanced → API Key (v3 "API Key").
# 3. Form ID: open the form; the numeric ID is in the URL / embed snippet.
# Copy this file to .env.local for local dev, and set the same vars in Vercel.
KIT_API_KEY=your_kit_api_key_here
KIT_FORM_ID=your_kit_form_id_here

# Anthropic API key — powers the mobile app's AI food-calorie scanner
# (/api/analyze-food). Create one at https://console.anthropic.com.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
